# ───────── Python ─────────
__pycache__/
*.py[cod]
*.egg-info/
.ipynb_checkpoints/
.venv/
venv/

# ───────── Secrets / env ─────────
.env
*.key

# ───────── Logs / runtime ─────────
logs/
*.log

# ───────── MLflow experiment store ─────────
mlruns/
mlartifacts/

# ───────── DVC (cache + local remote are not committed; .dvc meta IS) ─────────
.dvc/cache/
.dvc/tmp/
.dvc/config.local
/dvcstore/

# ───────── Notebook / eval outputs ─────────
# 재현 가능한 그림은 제외(요약 JSON은 커밋)
notebooks/*.html
notebooks/*.png
notebooks/.ipynb_checkpoints/
notebooks/human_ratings.csv
notebooks/human_ratings_template.csv

# ───────── OS / Office temp ─────────
.DS_Store
Thumbs.db
~$*
